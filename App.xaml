<Application x:Class="PsiTun.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:PsiTun.Views"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <SolidColorBrush x:Key="ConnectedBrush" Color="#4CAF50"/>
        <SolidColorBrush x:Key="DisconnectedBrush" Color="#F44336"/>
        <SolidColorBrush x:Key="ConnectingBrush" Color="#FFC107"/>
        <SolidColorBrush x:Key="BgBrush" Color="#1E1E2E"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#2D2D3F"/>
        <SolidColorBrush x:Key="TextBrush" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="SubtleBrush" Color="#A0A0B0"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <views:BoolToVisInvertConverter x:Key="BoolToVisInvert"/>
        <Style TargetType="Window" x:Key="AppWindow">
            <Setter Property="Background" Value="{StaticResource BgBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Application.Resources>
</Application>
