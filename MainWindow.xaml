<Window x:Class="PsiTun.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource AppWindow}"
        Title="PsiTun" Height="450" Width="620"
        MinHeight="450" MinWidth="600"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Status bar -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                CornerRadius="6" Padding="12 10" Margin="0 0 0 10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Ellipse Grid.Column="0" Width="12" Height="12" Margin="0 0 10 0"
                         Fill="{Binding StatusBrush}"/>

                <TextBlock Grid.Column="1" Text="{Binding StatusText}"
                           VerticalAlignment="Center"
                           FontSize="14" FontWeight="SemiBold"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBlock Text="{Binding PingLabelText}"
                               Visibility="{Binding PingLabelVisible,
                                    Converter={StaticResource BoolToVis}}"
                               VerticalAlignment="Center"
                               FontSize="12" Foreground="#80FFFFFF"
                               Margin="0 0 15 0"/>
                    <Button Content="Подключиться"
                            Command="{Binding ConnectCommand}"
                            Visibility="{Binding IsConnected,
                                Converter={StaticResource BoolToVisInvert}}"
                            Width="120" Height="32" Margin="5 0"
                            Background="#4CAF50" Foreground="White"
                            BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"/>
                    <Button Content="Отключиться"
                            Command="{Binding DisconnectCommand}"
                            Visibility="{Binding IsConnected,
                                Converter={StaticResource BoolToVis}}"
                            Width="120" Height="32" Margin="5 0"
                            Background="#F44336" Foreground="White"
                            BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Subscription row -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}"
                CornerRadius="6" Padding="10" Margin="0 0 0 10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="SubscriptionBox"
                         Foreground="{StaticResource TextBrush}"
                         CaretBrush="{StaticResource TextBrush}"
                         BorderThickness="0" Background="Transparent"
                         VerticalAlignment="Center" FontSize="12"
                         Text="{Binding SubscriptionUrl, UpdateSourceTrigger=LostFocus}"
                         GotFocus="SubscriptionBox_GotFocus"
                         LostFocus="SubscriptionBox_LostFocus"/>

                <Button Grid.Column="1" Content="Добавить / обновить"
                        Command="{Binding RefreshSubscriptionCommand}"
                        Width="150" Height="28"
                        Background="#5C6BC0" Foreground="White"
                        BorderThickness="0" Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- Server list -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}"
                CornerRadius="6" Padding="4" Margin="0 0 0 10">
            <Grid>
                <ListBox Name="MainServerList"
                         ItemsSource="{Binding Servers}"
                         Background="Transparent"
                         Foreground="{StaticResource TextBrush}"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <RadioButton Grid.Column="0"
                                             IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                             GroupName="Servers"
                                             VerticalAlignment="Center"
                                             Margin="0 0 8 0"
                                             Checked="ServerRadio_Checked"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding DisplayText}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="10 8"/>
                            <Setter Property="Margin" Value="2"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" Background="Transparent"
                                                CornerRadius="4" Padding="10 8">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#3F51B5"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#3A3A50"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
                <TextBlock Text="by Rockwell@control"
                           Foreground="#30FFFFFF"
                           FontSize="10" FontStyle="Italic"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Bottom"
                           Margin="0 0 8 4"
                           IsHitTestVisible="False"/>
            </Grid>
        </Border>

        <!-- Bottom bar -->
        <Border Grid.Row="3" Padding="4 0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Content="Пинг" Command="{Binding PingCommand}"
                            Width="60" Height="24"
                            Background="#455A64" Foreground="White"
                            BorderThickness="0" Cursor="Hand" FontSize="11"
                            Margin="0,0,5,0"/>
                    <Button Content="Настройки" Command="{Binding SettingsCommand}"
                            Width="75" Height="24"
                            Background="#5C6BC0" Foreground="White"
                            BorderThickness="0" Cursor="Hand" FontSize="11"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding XrayStatusText}"
                               Foreground="{Binding XrayStatusBrush}"
                               FontSize="12" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0 0 12 0"/>
                    <TextBlock Text="{Binding TunStatusText}"
                               Foreground="{Binding TunStatusBrush}"
                               FontSize="12" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0 0 15 0"/>
                    <CheckBox Content="Автозапуск"
                              IsChecked="{Binding AutoStart}"
                              Foreground="{StaticResource SubtleBrush}"
                              FontSize="12" Margin="0 0 15 0"/>
                    <CheckBox Content="Авто-подключение"
                              IsChecked="{Binding AutoConnect}"
                              Foreground="{StaticResource SubtleBrush}"
                              FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Log -->
        <Border Grid.Row="4" Background="{StaticResource SurfaceBrush}"
                CornerRadius="4" Padding="4" Margin="0 5 0 0" Height="80">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <CheckBox x:Name="AutoScrollCheck" Grid.Row="0"
                          Content="Автопрокрутка" IsChecked="{Binding AutoScroll}"
                          Foreground="{StaticResource SubtleBrush}"
                          FontSize="10" HorizontalAlignment="Right"
                          Margin="0,0,4,2"/>
                <RichTextBox x:Name="LogBox" Grid.Row="1"
                         Background="Transparent"
                         Foreground="#90A4AE"
                         BorderThickness="0"
                         IsReadOnly="True"
                         FontFamily="Consolas" FontSize="10"
                         VerticalScrollBarVisibility="Auto"
                         IsDocumentEnabled="True">
                    <RichTextBox.Resources>
                        <Style TargetType="Paragraph">
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="LineHeight" Value="6"/>
                            <Setter Property="LineStackingStrategy" Value="MaxHeight"/>
                        </Style>
                    </RichTextBox.Resources>
                </RichTextBox>
            </Grid>
        </Border>
    </Grid>
</Window>
