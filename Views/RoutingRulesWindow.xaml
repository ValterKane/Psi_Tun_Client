<Window x:Class="PsiTun.Views.RoutingRulesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Routing Rules" Height="520" Width="780"
        MinHeight="400" MinWidth="640"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="#1E1E2E" Foreground="#E0E0E0"
        FontFamily="Segoe UI" FontSize="12"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#252535"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="#252535"/>
            <Setter Property="AlternatingRowBackground" Value="#2A2A3A"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#3D3D50"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="SelectionUnit" Value="Cell"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#2D2D3F"/>
            <Setter Property="Foreground" Value="#B0B0C0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CaretBrush" Value="#E0E0E0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E0E0E0"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Rules DataGrid -->
        <DataGrid x:Name="RulesGrid" Grid.Row="0" Margin="0,0,0,10"
                  AlternationCount="2" CanUserResizeRows="False"
                  RowHeight="32">
            <DataGrid.Columns>
                <!-- Enabled -->
                <DataGridCheckBoxColumn Header="✓"
                    Binding="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged}"
                    Width="36">
                    <DataGridCheckBoxColumn.ElementStyle>
                        <Style TargetType="CheckBox">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridCheckBoxColumn.ElementStyle>
                </DataGridCheckBoxColumn>

                <!-- Type -->
                <DataGridComboBoxColumn Header="Type"
                    SelectedItemBinding="{Binding MatchType, UpdateSourceTrigger=PropertyChanged}"
                    Width="130">
                    <DataGridComboBoxColumn.ElementStyle>
                        <Style TargetType="ComboBox">
                            <Setter Property="Background" Value="#1E1E2E"/>
                            <Setter Property="Foreground" Value="#E0E0E0"/>
                        </Style>
                    </DataGridComboBoxColumn.ElementStyle>
                    <DataGridComboBoxColumn.EditingElementStyle>
                        <Style TargetType="ComboBox">
                            <Setter Property="Background" Value="#1E1E2E"/>
                            <Setter Property="Foreground" Value="#E0E0E0"/>
                        </Style>
                    </DataGridComboBoxColumn.EditingElementStyle>
                </DataGridComboBoxColumn>

                <!-- Value -->
                <DataGridTextColumn Header="Value"
                    Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                    Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Protocol filter -->
                <DataGridComboBoxColumn Header="Prot"
                    SelectedItemBinding="{Binding Protocol, UpdateSourceTrigger=PropertyChanged}"
                    Width="70">
                    <DataGridComboBoxColumn.ElementStyle>
                        <Style TargetType="ComboBox">
                            <Setter Property="Background" Value="#1E1E2E"/>
                            <Setter Property="Foreground" Value="#E0E0E0"/>
                        </Style>
                    </DataGridComboBoxColumn.ElementStyle>
                    <DataGridComboBoxColumn.EditingElementStyle>
                        <Style TargetType="ComboBox">
                            <Setter Property="Background" Value="#1E1E2E"/>
                            <Setter Property="Foreground" Value="#E0E0E0"/>
                        </Style>
                    </DataGridComboBoxColumn.EditingElementStyle>
                </DataGridComboBoxColumn>

                <!-- Port filter -->
                <DataGridTextColumn Header="Port"
                    Binding="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                    Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Action -->
                <DataGridComboBoxColumn Header="Action"
                    SelectedItemBinding="{Binding Action, UpdateSourceTrigger=PropertyChanged}"
                    Width="80">
                    <DataGridComboBoxColumn.ElementStyle>
                        <Style TargetType="ComboBox">
                            <Setter Property="Background" Value="#1E1E2E"/>
                            <Setter Property="Foreground" Value="#E0E0E0"/>
                        </Style>
                    </DataGridComboBoxColumn.ElementStyle>
                    <DataGridComboBoxColumn.EditingElementStyle>
                        <Style TargetType="ComboBox">
                            <Setter Property="Background" Value="#1E1E2E"/>
                            <Setter Property="Foreground" Value="#E0E0E0"/>
                        </Style>
                    </DataGridComboBoxColumn.EditingElementStyle>
                </DataGridComboBoxColumn>

                <!-- Delete button -->
                <DataGridTemplateColumn Header="" Width="36">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="✕"
                                    Width="24" Height="24"
                                    Background="Transparent"
                                    Foreground="#F44336"
                                    BorderThickness="0"
                                    FontSize="14" FontWeight="Bold"
                                    Click="DeleteRule_Click"
                                    Tag="{Binding}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Bottom buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="+ Add Rule"
                    Style="{StaticResource ActionButton}"
                    Background="#5C6BC0"
                    Click="AddRule_Click" Margin="0,0,8,0"/>
            <Button Content="Reset to Defaults"
                    Style="{StaticResource ActionButton}"
                    Background="#455A64"
                    Click="ResetDefaults_Click" Margin="0,0,8,0"/>
            <Button Content="Save"
                    Style="{StaticResource ActionButton}"
                    Background="#43A047"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
