<Window x:Class="PsiTun.FirstRunWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PsiTun — Первый запуск" Height="300" Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize" WindowStyle="SingleBorderWindow"
        Background="#1E1E2E" Foreground="#E0E0E0"
        FontFamily="Segoe UI" FontSize="13">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Добро пожаловать в Psi-Tun"
                   FontSize="18" FontWeight="Bold" Margin="0,0,0,5"/>

        <TextBlock Grid.Row="1" Text="Введите URL подписки на VPN для начала работы.&#10;Поддерживаются: VLESS, VMess, Trojan, Shadowsocks, Base64, Clash, sing-box."
                   FontSize="12" Foreground="#A0A0B0"
                   TextWrapping="Wrap" Margin="0,0,0,15"/>

        <TextBox Grid.Row="2"
                 Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"
                 Height="32" FontSize="13" Margin="0,0,0,10"
                 Background="#2D2D3F" Foreground="#E0E0E0" CaretBrush="#E0E0E0"
                 BorderThickness="0" Padding="8,5"/>

        <ProgressBar Grid.Row="3"
                     Height="4" IsIndeterminate="True"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                     Margin="0,0,0,10"/>

        <TextBlock Grid.Row="4"
                   Text="{Binding Status}"
                   Visibility="{Binding HasStatus, Converter={StaticResource BoolToVis}}"
                   FontSize="12" Foreground="#F44336" TextWrapping="Wrap"/>
        
        <TextBlock Grid.Row="4" Text="(с) ПСИ-корпус твой друг. Доверяй ПСИ-корпусу!"
                   Foreground="#30FFFFFF"
                   FontSize="10" FontStyle="Italic"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Bottom"
                   Margin="0 0 8 4"
                   IsHitTestVisible="False"/>

        <StackPanel Grid.Row="5" Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Пропустить" Command="{Binding SkipCommand}"
                    Width="100" Height="32" Margin="5,0"
                    Background="#555565" Foreground="#E0E0E0"
                    BorderThickness="0" Cursor="Hand"/>
            <Button Content="Загрузить" Command="{Binding LoadCommand}"
                    Width="100" Height="32" Margin="5,0,0,0"
                    Background="#5C6BC0" Foreground="White"
                    BorderThickness="0" Cursor="Hand" FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</Window>
